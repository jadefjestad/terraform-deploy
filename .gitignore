# ─── Terraform ────────────────────────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info
crash.log
crash.*.log

# Plan binary output
*.tfplan
*tfplan*

# Sensitive variable files (keep .example files for reference)
*.tfvars
*.tfvars.json
!*.tfvars.example

# Override files (local-only customisation)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# Terraform lock file is committed — do NOT ignore
# !.terraform.lock.hcl

# ─── Quality / Scanning Tools ────────────────────────────────────────────────
# Checkov
checkov-report.*
checkov_results/

# TFLint
.tflint/

# Infracost
infracost-*.json
.infracost/

# tfsec (legacy, kept in case)
tfsec-*.json

# ─── OIDC Setup Script Artefacts ─────────────────────────────────────────────
scripts/*.log
scripts/*.out

# ─── OS / IDE ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
